# ──────────────────────────────────────────────
# RealityCapture Helper — .gitignore
# ──────────────────────────────────────────────

# ── Large image source files ──────────────────
images/**/*.jpg
images/**/*.jpeg
images/**/*.png
images/**/*.tif
images/**/*.tiff
images/**/*.exr
images/**/*.hdr
images/**/*.dpx

# Camera raw formats
images/**/*.cr2
images/**/*.cr3
images/**/*.arw
images/**/*.nef
images/**/*.nrw
images/**/*.raf
images/**/*.orf
images/**/*.rw2
images/**/*.dng
images/**/*.raw
images/**/*.3fr
images/**/*.mef
images/**/*.mrw
images/**/*.pef
images/**/*.srw
images/**/*.x3f

# RC project / database files (binary, large)
images/**/*.rclicense
images/**/*.rcproj
images/**/*.db
images/**/*.db-shm
images/**/*.db-wal

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────
.venv/
venv/
env/
.conda/

# ── IDE / editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Output folders (generated, not versioned) ─
output/
out/
exports/

# ── Logs ─────────────────────────────────────
*.log
logs/
